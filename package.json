{
    "name": "catalogo",
    "version": "0.0.0",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build",
        "watch": "ng build --watch --configuration development",
        "test": "ng test",
        "docs": "compodoc -p tsconfig.app.json -d documentation",
        "docs:serve": "compodoc -p tsconfig.app.json -d documentation -s",
        "deploy": "npm run build && aws s3 sync dist/catalogo/browser s3://catalogo-app-1 --delete --region us-east-2",
        "cap:sync": "npx cap sync",
        "android:sync": "npm run build && npx cap sync android",
        "android:open": "npx cap open android"
    },
    "private": true,
    "packageManager": "npm@10.9.2",
    "dependencies": {
        "@angular/common": "^21.2.0",
        "@angular/compiler": "^21.2.0",
        "@angular/core": "^21.2.0",
        "@angular/forms": "^21.2.0",
        "@angular/platform-browser": "^21.2.0",
        "@angular/router": "^21.2.0",
        "@angular/service-worker": "^21.2.8",
        "@capacitor/android": "^8.3.1",
        "@capacitor/cli": "^8.3.1",
        "@capacitor/core": "^8.3.1",
        "aws-amplify": "^6.16.4",
        "rxjs": "~7.8.0",
        "tdesign-icons-svg": "^0.4.2",
        "three": "^0.184.0",
        "tslib": "^2.3.0"
    },
    "devDependencies": {
        "@angular/build": "^21.2.1",
        "@angular/cli": "^21.2.1",
        "@angular/compiler-cli": "^21.2.0",
        "@compodoc/compodoc": "^1.2.1",
        "@types/three": "^0.184.0",
        "jsdom": "^28.0.0",
        "prettier": "^3.8.1",
        "typescript": "~5.9.2",
        "vitest": "^4.0.8"
    }
}
